# LinkedIn API credentials — get these from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_URN=

# LLM provider — supports any provider LiteLLM handles (deepseek, openai, anthropic, etc.)
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# News source for the headliner command
# Options: hackernews (default, no key needed), newsapi (requires NEWS_API_KEY)
# NEWS_SOURCE=hackernews
# NEWS_API_KEY=

# Optional: path to custom ruleset YAML
# RULES_PATH=
